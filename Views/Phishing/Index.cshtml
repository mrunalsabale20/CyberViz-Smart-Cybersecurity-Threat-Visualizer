@model SmartCyberViz.ViewModels.PhishingViewModel
@{
    ViewData["Title"] = "Phishing URL Checker";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ── Page Header ───────────────────────────────────────────────── -->
<div class="page-header">
    <h1 class="page-title"><i class="bi bi-link-45deg me-2"></i>PHISHING URL CHECKER</h1>
    <p class="page-subtitle">Scan any URL through VirusTotal's 70+ security engines</p>
</div>

<!-- ── Scan Form ─────────────────────────────────────────────────── -->
<div class="cyber-card mb-4">
    <form asp-action="Index" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3 align-items-end">
            <div class="col-md-8">
                <label asp-for="Url" class="form-label">URL to Scan</label>
                <div class="input-group">
                    <span class="input-group-text"
                          style="background:var(--bg-secondary);border-color:var(--border-color);color:var(--accent-green);">
                        <i class="bi bi-link-45deg"></i>
                    </span>
                    <input asp-for="Url" class="form-control"
                           placeholder="https://suspicious-site.com/login" />
                </div>
                <span asp-validation-for="Url" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-cyber w-100 py-2" id="scanBtn">
                    <i class="bi bi-shield-check me-2"></i>SCAN URL
                </button>
            </div>
        </div>
        <p class="mt-2 mb-0" style="color:var(--text-muted); font-size:0.8rem;">
            <i class="bi bi-info-circle me-1"></i>
            Include full URL with http:// or https://. Scan may take 5–10 seconds.
        </p>
    </form>
</div>

<!-- ── Error ─────────────────────────────────────────────────────── -->
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert-cyber-danger p-3 mb-4 rounded">
        <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
    </div>
}

<!-- ── Results ───────────────────────────────────────────────────── -->
@if (Model.HasResult)
{
    var verdictColor = Model.Verdict switch
    {
        "Malicious" => "#ff3860",
        "Suspicious" => "#ffd700",
        _ => "#00ff88"
    };

    var verdictIcon = Model.Verdict switch
    {
        "Malicious" => "bi-x-octagon-fill",
        "Suspicious" => "bi-exclamation-triangle-fill",
        _ => "bi-check-circle-fill"
    };

    <!-- Verdict Banner -->
    <div class="cyber-card mb-4" style="border-color:@verdictColor;">
        <div class="row align-items-center">
            <div class="col-md-3 text-center border-end"
                 style="border-color:var(--border-color)!important;">
                <i class="bi @verdictIcon"
                   style="font-size:3rem; color:@verdictColor;"></i>
                <div class="mt-2">
                    <span class="badge px-3 py-2"
                          style="background:@verdictColor; color:@(Model.Verdict == "Suspicious" ? "#000" : "#fff"); font-size:1rem;">
                        @Model.Verdict.ToUpper()
                    </span>
                </div>
            </div>
            <div class="col-md-9 ps-4">
                <p class="section-title mb-1">Scanned URL</p>
                <div style="font-family:'Share Tech Mono',monospace;
                    color:var(--accent-green); font-size:0.9rem;
                    word-break:break-all; margin-bottom:1rem;">
                    @Model.Url
                </div>

                <!-- Detection ratio bar -->
                <div class="mb-2">
                    <div class="d-flex justify-content-between mb-1">
                        <span style="font-size:0.8rem; color:var(--text-muted);">
                            Detection Ratio
                        </span>
                        <span style="font-family:'Share Tech Mono',monospace;
                            color:@verdictColor; font-size:0.85rem;">
                            @Model.MaliciousVendors / @Model.TotalVendors engines
                        </span>
                    </div>
                    @if (Model.TotalVendors > 0)
                    {
                        var pct = (int)((double)Model.MaliciousVendors / Model.TotalVendors * 100);
                        <div style="background:var(--border-color); border-radius:4px; height:8px;">
                            <div style="width:@pct%; background:@verdictColor;
                            border-radius:4px; height:8px;
                            transition: width 1s ease;"></div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Stats row -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="stat-card danger">
                <div class="stat-number">@Model.MaliciousVendors</div>
                <div class="stat-label">Malicious Flags</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card warning">
                <div class="stat-number">@Model.TotalVendors</div>
                <div class="stat-label">Total Engines</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card @(Model.IsMalicious ? "danger" : "")">
                <div class="stat-number">
                    @(Model.IsMalicious ? "YES" : "NO")
                </div>
                <div class="stat-label">Malicious</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card info">
                <div class="stat-number" style="font-size:1.2rem;">
                    @Model.Verdict
                </div>
                <div class="stat-label">Final Verdict</div>
            </div>
        </div>
    </div>

    <!-- Safety Tips -->
    <div class="cyber-card">
        <p class="section-title"><i class="bi bi-lightbulb me-2"></i>Safety Recommendations</p>
        <div class="row g-3">
            @if (Model.IsMalicious)
            {
                <div class="col-md-6">
                    <div class="d-flex gap-2">
                        <i class="bi bi-x-circle-fill mt-1" style="color:var(--accent-red); flex-shrink:0;"></i>
                        <div>
                            <div style="color:var(--text-primary); font-weight:600;">Do NOT visit this URL</div>
                            <div style="color:var(--text-muted); font-size:0.85rem;">This URL has been flagged by multiple security engines as malicious.</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex gap-2">
                        <i class="bi bi-shield-x mt-1" style="color:var(--accent-red); flex-shrink:0;"></i>
                        <div>
                            <div style="color:var(--text-primary); font-weight:600;">Report to your IT team</div>
                            <div style="color:var(--text-muted); font-size:0.85rem;">If received via email, report it as phishing immediately.</div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="col-md-6">
                    <div class="d-flex gap-2">
                        <i class="bi bi-check-circle-fill mt-1" style="color:var(--accent-green); flex-shrink:0;"></i>
                        <div>
                            <div style="color:var(--text-primary); font-weight:600;">URL appears safe</div>
                            <div style="color:var(--text-muted); font-size:0.85rem;">No major security engines flagged this URL as malicious.</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex gap-2">
                        <i class="bi bi-eye mt-1" style="color:var(--accent-blue); flex-shrink:0;"></i>
                        <div>
                            <div style="color:var(--text-primary); font-weight:600;">Stay vigilant</div>
                            <div style="color:var(--text-muted); font-size:0.85rem;">Always verify the domain carefully before entering credentials.</div>
                        </div>
                    </div>
                </div>
            }
            <div class="col-md-6">
                <div class="d-flex gap-2">
                    <i class="bi bi-lock mt-1" style="color:var(--accent-yellow); flex-shrink:0;"></i>
                    <div>
                        <div style="color:var(--text-primary); font-weight:600;">Check for HTTPS</div>
                        <div style="color:var(--text-muted); font-size:0.85rem;">Ensure the site uses HTTPS before submitting any personal data.</div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="d-flex gap-2">
                    <i class="bi bi-clipboard-check mt-1" style="color:var(--accent-yellow); flex-shrink:0;"></i>
                    <div>
                        <div style="color:var(--text-primary); font-weight:600;">Verify the sender</div>
                        <div style="color:var(--text-muted); font-size:0.85rem;">If this link came from an email, confirm with the sender through a separate channel.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Show loading state on form submit
        document.querySelector('form').addEventListener('submit', function () {
            const btn = document.getElementById('scanBtn');
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>SCANNING...';
            btn.disabled = true;
        });
    </script>
}