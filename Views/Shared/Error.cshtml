@{
    ViewData["Title"] = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-center align-items-center" style="min-height:70vh;">
    <div class="cyber-card text-center" style="max-width:500px; border-color:var(--accent-red);">
        <i class="bi bi-exclamation-octagon-fill"
           style="font-size:4rem; color:var(--accent-red);"></i>
        <h2 class="mt-3"
            style="font-family:'Share Tech Mono',monospace; color:var(--accent-red);">
            SYSTEM ERROR
        </h2>
        <p style="color:var(--text-muted); margin:1rem 0;">
            An unexpected error occurred. Please try again or return to the dashboard.
        </p>
        <div class="d-flex gap-3 justify-content-center">
            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-cyber">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>
            <a asp-controller="Home" asp-action="Index"
                   class="btn btn-cyber btn-cyber-danger">
                <i class="bi bi-house me-2"></i>Home
            </a>
        </div>
    </div>
</div>