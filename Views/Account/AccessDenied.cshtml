@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-center align-items-center" style="min-height:70vh;">
    <div class="cyber-card text-center" style="max-width:500px; border-color:var(--accent-yellow);">
        <i class="bi bi-shield-lock-fill"
           style="font-size:4rem; color:var(--accent-yellow);"></i>
        <h2 class="mt-3"
            style="font-family:'Share Tech Mono',monospace; color:var(--accent-yellow);">
            ACCESS DENIED
        </h2>
        <p style="color:var(--text-muted); margin:1rem 0;">
            You do not have permission to access this resource.
            Please login with an authorized account.
        </p>
        <div class="d-flex gap-3 justify-content-center">
            <a asp-controller="Account" asp-action="Login" class="btn btn-cyber">
                <i class="bi bi-box-arrow-in-right me-2"></i>Login
            </a>
            <a asp-controller="Home" asp-action="Index"
                   class="btn btn-cyber btn-cyber-danger">
                <i class="bi bi-house me-2"></i>Home
            </a>
        </div>
    </div>
</div>