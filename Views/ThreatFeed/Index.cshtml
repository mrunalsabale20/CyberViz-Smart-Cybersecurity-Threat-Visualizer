@using SmartCyberViz.Controllers
@model ThreatFeedViewModel
@{
    ViewData["Title"] = "Threat Intelligence Feed";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ── Page Header ───────────────────────────────────────────────── -->
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title"><i class="bi bi-rss me-2"></i>THREAT INTELLIGENCE FEED</h1>
        <p class="page-subtitle">Aggregated threat activity across all modules</p>
    </div>
    <div style="font-family:'Share Tech Mono',monospace; color:var(--text-muted); font-size:0.8rem;">
        <span style="color:var(--accent-green);">&#9679;</span> LIVE
        &nbsp;|&nbsp; @DateTime.Now.ToString("HH:mm:ss")
    </div>
</div>

<!-- ── Summary Stats ─────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-number">@Model.TotalThreats</div>
            <div class="stat-label">Total Threats</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card info">
            <div class="stat-number">@Model.TotalScans</div>
            <div class="stat-label">Total Scans</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card danger">
            <div class="stat-number">@Model.HighRiskIPs.Count</div>
            <div class="stat-label">High Risk IPs</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card warning">
            <div class="stat-number">@Model.MaliciousUrls.Count</div>
            <div class="stat-label">Malicious URLs</div>
        </div>
    </div>
</div>

<div class="row g-4">

    <!-- ── Left Column ───────────────────────────────────────────── -->
    <div class="col-lg-8">

        <!-- Recent Threat Logs -->
        <div class="cyber-card mb-4">
            <p class="section-title">
                <i class="bi bi-clock-history me-2"></i>Recent Threat Detections
            </p>
            @if (Model.RecentThreats.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>IP Address</th>
                                <th>Type</th>
                                <th>Severity</th>
                                <th>Location</th>
                                <th>Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.RecentThreats)
                            {
                                var color = t.Severity switch
                                {
                                    "Critical" => "#ff3860",
                                    "High" => "#ff6b35",
                                    "Medium" => "#ffd700",
                                    _ => "#00b4ff"
                                };
                                <tr>
                                    <td style="font-family:'Share Tech Mono',monospace;
                                        color:var(--accent-green); font-size:0.9rem;">
                                        @t.IPAddress
                                    </td>
                                    <td style="color:#64748b;">@t.ThreatType</td>
                                    <td>
                                        <span class="badge"
                                              style="background:@color;
                                            color:@(t.Severity == "Medium" ? "#000" : "#fff");">
                                            @t.Severity
                                        </span>
                                    </td>
                                    <td style="color:var(--text-muted); font-size:0.85rem;">
                                        @t.City @t.Country
                                    </td>
                                    <td style="color:var(--text-muted); font-size:0.8rem;
                                        font-family:'Share Tech Mono',monospace;">
                                        @t.DetectedAt.ToString("HH:mm:ss")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4" style="color:var(--text-muted);">
                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                    No threat logs yet. Visit the Attack Map and load demo threats.
                </div>
            }
        </div>

        <!-- Recent IP Reports -->
        <div class="cyber-card mb-4">
            <p class="section-title">
                <i class="bi bi-globe me-2"></i>Recent IP Reputation Checks
            </p>
            @if (Model.RecentIPReports.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>IP Address</th>
                                <th>Abuse Score</th>
                                <th>ISP</th>
                                <th>Country</th>
                                <th>Checked</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.RecentIPReports)
                            {
                                var scoreColor = r.AbuseConfidenceScore >= 80 ? "#ff3860"
                                              : r.AbuseConfidenceScore >= 50 ? "#ff6b35"
                                              : r.AbuseConfidenceScore >= 20 ? "#ffd700"
                                              : "#00ff88";
                                <tr>
                                    <td style="font-family:'Share Tech Mono',monospace;
                                        color:var(--accent-green); font-size:0.9rem;">
                                        @r.IPAddress
                                    </td>
                                    <td>
                                        <span style="color:@scoreColor; font-weight:700;
                                            font-family:'Share Tech Mono',monospace;">
                                            @r.AbuseConfidenceScore%
                                        </span>
                                    </td>
                                        <td style="color:var(--text-muted); font-size:0.85rem;">
                                        @(r.ISP.Length > 25 ? r.ISP[..25] + "…" : r.ISP)
                                    </td>
                                    <td style="color:var(--text-muted);">@r.CountryCode</td>
                                    <td style="color:var(--text-muted); font-size:0.8rem;
                                        font-family:'Share Tech Mono',monospace;">
                                        @r.CheckedAt.ToString("HH:mm:ss")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4" style="color:var(--text-muted);">
                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                    No IP reports yet. Use the IP Analysis tool to get started.
                </div>
            }
        </div>

        <!-- Recent Phishing Checks -->
        <div class="cyber-card">
            <p class="section-title">
                <i class="bi bi-link-45deg me-2"></i>Recent URL Scans
            </p>
            @if (Model.RecentPhishing.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>URL</th>
                                <th>Verdict</th>
                                <th>Detections</th>
                                <th>Scanned</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.RecentPhishing)
                            {
                                var vColor = p.Verdict switch
                                {
                                    "Malicious" => "#ff3860",
                                    "Suspicious" => "#ffd700",
                                    _ => "#00ff88"
                                };
                                <tr>
                                    <td style="max-width:250px; overflow:hidden;
                                        text-overflow:ellipsis; white-space:nowrap;
                                        font-family:'Share Tech Mono',monospace;
                                        color:#1a56db; font-size:0.8rem;">
                                        @p.Url
                                    </td>
                                    <td>
                                        <span class="badge"
                                              style="background:@vColor;
                                            color:@(p.Verdict == "Suspicious" ? "#000" : "#fff");">
                                            @p.Verdict
                                        </span>
                                    </td>
                                    <td style="color:var(--text-muted); font-size:0.85rem;">
                                        @p.MaliciousVendors / @p.TotalVendors
                                    </td>
                                    <td style="color:var(--text-muted); font-size:0.8rem;
                                        font-family:'Share Tech Mono',monospace;">
                                        @p.CheckedAt.ToString("HH:mm:ss")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4" style="color:var(--text-muted);">
                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                    No URL scans yet. Use the Phishing Checker to get started.
                </div>
            }
        </div>
    </div>

    <!-- ── Right Column ───────────────────────────────────────────── -->
    <div class="col-lg-4">

        <!-- High Risk IPs -->
        <div class="cyber-card mb-4">
            <p class="section-title">
                <i class="bi bi-exclamation-triangle me-2"
                   style="color:var(--accent-red);"></i>Top High Risk IPs
            </p>
            @if (Model.HighRiskIPs.Any())
            {
                @foreach (var ip in Model.HighRiskIPs)
                {
                    <div class="d-flex justify-content-between align-items-center mb-3 pb-3"
                         style="border-bottom:1px solid var(--border-color);">
                        <div>
                            <div style="font-family:'Share Tech Mono',monospace;
                                color:var(--accent-green); font-size:0.9rem;">
                                @ip.IPAddress
                            </div>
                            <div style="color:var(--text-muted); font-size:0.75rem;">
                                @ip.ISP — @ip.CountryCode
                            </div>
                        </div>
                        <span style="font-family:'Share Tech Mono',monospace;
                            color:var(--accent-red); font-weight:700;">
                            @ip.AbuseConfidenceScore%
                        </span>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-3" style="color:var(--text-muted); font-size:0.85rem;">
                    <i class="bi bi-shield-check d-block fs-3 mb-1"
                       style="color:var(--accent-green);"></i>
                    No high risk IPs found
                </div>
            }
        </div>

        <!-- Malicious URLs -->
        <div class="cyber-card mb-4">
            <p class="section-title">
                <i class="bi bi-bug me-2" style="color:var(--accent-red);"></i>
                Confirmed Malicious URLs
            </p>
            @if (Model.MaliciousUrls.Any())
            {
                @foreach (var url in Model.MaliciousUrls)
                {
                    <div class="mb-3 pb-3" style="border-bottom:1px solid var(--border-color);">
                        <div style="font-family:'Share Tech Mono',monospace;
                            color:var(--accent-red); font-size:0.75rem;
                            word-break:break-all; margin-bottom:3px;">
                            @(url.Url.Length > 40 ? url.Url[..40] + "…" : url.Url)
                        </div>
                        <div style="color:var(--text-muted); font-size:0.75rem;">
                            @url.MaliciousVendors/@url.TotalVendors engines &nbsp;·&nbsp;
                            @url.CheckedAt.ToString("dd MMM HH:mm")
                        </div>
                    </div>
                }
            }
            else
            {
                <div class= "text-center py-3" style = "color:var(--text-muted); font-size:0.85rem;">
                    <i class="bi bi-shield-check d-block fs-3 mb-1"
                       style="color:var(--accent-green);"></i>
                    No malicious URLs recorded
                </div>
            }
        </div>

        <!-- Cyber Tips -->
        <div class="cyber-card">
            <p class="section-title">
                <i class="bi bi-lightbulb me-2"
                   style="color:var(--accent-yellow);"></i>Security Tips
            </p>
            @foreach (var tip in new[] {
                new { Icon="bi-shield-check",    Color="var(--accent-green)",  Text="Enable two-factor authentication on all critical accounts." },
                new { Icon="bi-arrow-repeat",    Color="var(--accent-blue)",   Text="Update your passwords every 90 days and never reuse them." },
                new { Icon="bi-wifi-off",        Color="var(--accent-yellow)", Text="Avoid public Wi-Fi for sensitive transactions without a VPN." },
                new { Icon="bi-envelope-slash",  Color="var(--accent-red)",    Text="Never click links in unsolicited emails — verify the sender first." },
                new { Icon="bi-hdd-fill",        Color="var(--accent-green)",  Text="Keep regular offline backups to protect against ransomware." }
            })
            {
                <div class="d-flex gap-2 mb-3">
                    <i class="bi @tip.Icon mt-1 flex-shrink-0"
                       style="color:@tip.Color;"></i>
                    <span style="color:var(--text-muted); font-size:0.85rem;">@tip.Text</span>
                </div>
            }
        </div>
    </div>
</div>